# Bot token from https://discord.com/developers/applications -> Bot
DISCORD_TOKEN=your-bot-token

# Application ID (General Information -> App ID)
DISCORD_CLIENT_ID=your-application-id

# Optional: set for instant command updates during development (guild scope)
# Leave blank to register commands globally (can take up to 1 hour to propagate)
DISCORD_GUILD_ID=

# Channel where the daily cron job posts
DAILY_CHANNEL_ID=channel-id
